{
  "name": "@khimaros/pi-webui",
  "version": "0.5.1",
  "type": "module",
  "description": "a simple, standalone webui for pi.dev",
  "keywords": [
    "pi-package"
  ],
  "license": "GPL-3.0-or-later",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/khimaros/pi-webui.git"
  },
  "homepage": "https://github.com/khimaros/pi-webui#readme",
  "bugs": {
    "url": "https://github.com/khimaros/pi-webui/issues"
  },
  "main": "dist/server/index.js",
  "bin": {
    "pi-webui": "dist/server/index.js"
  },
  "pi": {
    "extensions": ["dist/extension/index.js"]
  },
  "files": [
    "dist",
    "public",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc && node -e \"require('fs').chmodSync('dist/server/index.js', 0o755)\"",
    "prepack": "npm run build",
    "start": "node dist/server/index.js",
    "test": "npm run build && node --test test/*.test.mjs"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@earendil-works/pi-coding-agent": "^0.74.0",
    "ws": "^8.18.3"
  },
  "devDependencies": {
    "@types/node": "^25.6.2",
    "@types/ws": "^8.18.1",
    "typescript": "^6.0.3"
  }
}
